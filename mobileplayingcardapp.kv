#:kivy 2.3.0

<MainMenu>:
    md_bg_color: self.theme_cls.surfaceColor
    MDFloatLayout:
        Image: #Main Game Icon
            source: "assets/img/Icon.png"
            pos_hint: {"center_x": 0.5, "center_y": 0.8}
            size_hint: None, None
            size: "250dp", "250dp"
            fit_mode: "scale-down"
        MDBoxLayout:
            orientation: 'vertical'
            pos_hint: {'center_x': .5, 'center_y': .4}
            adaptive_size: True
            spacing: dp(20)
            MDButton: #New Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu")
                    root.manager.current = "NewGame"
                MDButtonText:
                    text: app.resume_game_check()
                    font_style: "cataway"
                    role: "small"
            MDButton: #Shop Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu")
                    app.set_up_shop()
                    root.manager.current = "MDShop"
                MDButtonText:
                    text: "Shop"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Stats Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu")
                    root.manager.current = "Stats"
                MDButtonText:
                    text: "Game Statistics"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Quit Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: app.stop()
                MDButtonText:
                    text: "Exit Game"
                    font_style: "cataway"
                    role: "small"
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Menu")
                root.manager.current = "Settings"

<NewGame>:
    md_bg_color: self.theme_cls.surfaceColor
    MDFloatLayout:
        MDLabel:
            text: "New Game!"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        Image: #NewGame Icon
            source: "assets/img/NewGame_Icon.png"
            pos_hint: {"center_x": 0.5, "center_y": 0.8}
            size_hint: None, None
            size: "250dp", "250dp"
            fit_mode: "scale-down"
        MDBoxLayout:
            orientation: 'vertical'
            pos_hint: {'center_x': .5, 'center_y': .4}
            adaptive_size: True
            spacing: dp(20)
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    app.start_game("threes")
                    root.manager.current = "MDThrees"
                MDButtonText:
                    text: "Threes"
                    font_style: "cataway"
                    role: "small"
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    app.start_game("rummy")
                    root.manager.current = "MDRummy"
                MDButtonText:
                    text: "Rummy"
                    font_style: "cataway"
                    role: "small"
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    app.start_game("memory")
                    root.manager.current = "MDMemory"
                MDButtonText:
                    text: "Memory"
                    font_style: "cataway"
                    role: "small"
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    root.manager.current = "Rules"
                MDButtonText:
                    text: "Rules"
                    font_style: "cataway"
                    role: "small"

        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back()
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("NewGame")
                root.manager.current = "Pause"
<MDThrees>:
    md_bg_color: self.theme_cls.surfaceColor
    MDFloatLayout:
        MDIconButton: #Pause Button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "pause"
            on_release: 
                app.sm_stacky("MDThrees")
                root.manager.current = "Pause"
        MDLabel:
            id: timer
            text: "00:00"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        MDRelativeLayout:
            adaptive_size: True
            id: ai_hand1
            pos_hint: {"center_y":0.8, "center_x":0.4}
        MDRelativeLayout:
            adaptive_size: True
            id: ai_hand2
            pos_hint: {"center_y":0.8, "center_x":0.5}
        MDRelativeLayout:
            adaptive_size: True
            id: ai_hand3
            pos_hint: {"center_y":0.8, "center_x":0.6}

        MDRelativeLayout:
            adaptive_size: True
            id: deck
            pos_hint: {"center_y":0.5, "center_x":0.5}

        MDRelativeLayout:
            adaptive_size: True
            id: hand1
            pos_hint: {"center_y":0.3, "center_x":0.4}
        MDRelativeLayout:
            adaptive_size: True
            id: hand2
            pos_hint: {"center_y":0.3, "center_x":0.5}
        MDRelativeLayout:
            adaptive_size: True
            id: hand3
            pos_hint: {"center_y":0.3, "center_x":0.6}

        MDBoxLayout:
            orientation: "horizontal"
            id: playerview
            adaptive_height: True
            pos_hint: {"center_x": 0.5,"center_y":0.1}
            size_hint_x: 1
            size_hint_y: 0.2
            HandLayout:
                id: hand
                orientation: "horizontal"
                pos_hint: {"center_x": 0.5,"center_y":0.5}
                width: (self.parent.width - dp(100))
        
