#:kivy 2.3.0

<MainMenu>:
    md_bg_color: self.theme_cls.surfaceColor #Sets the background colour of the screen
    MDFloatLayout:
        Image: #Main Game Icon
            source: "assets/img/Icon.png"
            pos_hint: {"center_x": 0.5, "center_y": 0.8}
            size_hint: None, None
            size: "250dp", "250dp"
            fit_mode: "scale-down"
        MDBoxLayout:
            id: test
            orientation: 'vertical'
            pos_hint: {'center_x': .5, 'center_y': .4}
            adaptive_size: True
            spacing: dp(20)
            MDButton: #New Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu") #Adds the Menu screen to the previous screen stack
                    root.manager.current = "NewGame" #Changes the screen to the New Game section
                MDButtonText:
                    text: app.resume_game_check()
                    font_style: "cataway"
                    role: "small"
            MDButton: #Shop Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu") #Adds the Menu screen to the previous screen stack
                    app.set_up_shop() #Intialises all required objects for the shop section to operate
                    root.manager.current = "MDShop" #Changes the screen to the Shop section
                MDButtonText:
                    text: "Shop"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Stats Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu") #Adds the Menu screen to the previous screen stack
                    root.manager.current = "Stats" #Changes the screen to the Stats section
                MDButtonText:
                    text: "Game Statistics"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Quit Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: app.stop() #Closes the app
                MDButtonText:
                    text: "Exit Game"
                    font_style: "cataway"
                    role: "small"
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Menu") #Adds the Menu screen to the previous screen stack
                root.manager.current = "Settings" #Changes the screen to the Settings section

<NewGame>:
    md_bg_color: self.theme_cls.surfaceColor #Sets the background colour of the screen
    MDFloatLayout:
        MDLabel: #Title
            text: "New Game!"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        Image: #NewGame Icon
            source: "assets/img/NewGame_Icon.png"
            pos_hint: {"center_x": 0.5, "center_y": 0.8}
            size_hint: None, None
            size: "250dp", "250dp"
            fit_mode: "scale-down"
        MDBoxLayout: #Layout for Game buttons
            orientation: 'vertical'
            pos_hint: {'center_x': .5, 'center_y': .4}
            adaptive_size: True
            spacing: dp(20)
            MDButton: #Threes Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame") #Adds the New Game screen to the previous screen stack
                    app.start_game("threes") #Starts a threes game
                    root.manager.current = "MDThrees" #Changes the screen to the Threes section
                MDButtonText:
                    text: "Threes"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Rummy Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame") #Adds the New Game screen to the previous screen stack
                    app.start_game("rummy") #Starts a rummy game
                    root.manager.current = "MDRummy" #Changes the screen to the Rummy section
                MDButtonText:
                    text: "Rummy"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Memory Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame") #Adds the New Game screen to the previous screen stack
                    app.start_game("memory") #Starts a memory game
                    root.manager.current = "MDMemory" #Changes the screen to the memory section
                MDButtonText:
                    text: "Memory"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Rules Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame") #Adds the New Game screen to the previous screen stack
                    root.manager.current = "Rules" #Changes the screen to the rules section
                MDButtonText:
                    text: "Rules"
                    font_style: "cataway"
                    role: "small"

        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back() #Changes screen to the previous one
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("NewGame") #Adds the New Game screen to the previous screen stack
                root.manager.current = "Settings" #Changes the screen to the settings section
<MDThrees>:
    md_bg_color: self.theme_cls.surfaceColor #Sets the background colour of the screen
    MDFloatLayout:
        MDIconButton: #Pause Button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "pause"
            on_release: 
                app.sm_stacky("MDThrees")
                app.threes.stop_timer()
                root.manager.current = "Settings"
        MDLabel:
            id: timer
            text: "00:00"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        MDRelativeLayout:
            adaptive_size: True
            id: ai_hand1
            pos_hint: {"center_y":0.8, "center_x":0.4}
        MDRelativeLayout:
            adaptive_size: True
            id: ai_hand2
            pos_hint: {"center_y":0.8, "center_x":0.5}
        MDRelativeLayout:
            adaptive_size: True
            id: ai_hand3
            pos_hint: {"center_y":0.8, "center_x":0.6}

        MDRelativeLayout:
            adaptive_size: True
            id: deck
            pos_hint: {"center_y":0.5, "center_x":0.5}

        MDRelativeLayout:
            adaptive_size: True
            id: hand1
            pos_hint: {"center_y":0.3, "center_x":0.4}
        MDRelativeLayout:
            adaptive_size: True
            id: hand2
            pos_hint: {"center_y":0.3, "center_x":0.5}
        MDRelativeLayout:
            adaptive_size: True
            id: hand3
            pos_hint: {"center_y":0.3, "center_x":0.6}

        MDBoxLayout:
            orientation: "horizontal"
            id: playerview
            adaptive_height: True
            pos_hint: {"center_x": 0.5,"center_y":0.1}
            size_hint_x: 1
            size_hint_y: 0.2
            HandLayout:
                id: hand
                orientation: "horizontal"
                pos_hint: {"center_x": 0.5,"center_y":0.5}
                width: (self.parent.width - dp(100))
        
