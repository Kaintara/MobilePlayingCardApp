<Rules>:
    md_bg_color: self.theme_cls.backgroundColor
    MDFloatLayout:
        MDLabel:
            text: "Rules"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.5
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.7}
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-left"
                pos_hint: {"center_x":0.2,"center_y": 0.8}
                on_release: app.left("Rules")
            Carousel:
                id: carou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "center_y":0.5, "right":0.5}
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: 'vertical'
                        padding: "20dp"
                        spacing: "20dp"
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Threes"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Threes!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: 'vertical'
                        padding: "20dp"
                        spacing: "20dp"
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Rummy"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Rummy!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: 'vertical'
                        padding: "20dp"
                        spacing: "20dp"
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Memory"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Memory!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-right"
                pos_hint: {"center_x":0.8,"center_y": 0.8}
                on_release: app.right("Rules")
        MDIconButton: #Back button
            pos_hint: {"center_x":0.05, "center_y": 0.95}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back()
        MDIconButton: #Settings Button\
            pos_hint: {"center_x":0.95, "center_y": 0.95}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Rules")
                root.manager.current = "Settings"

<MDShop>:
    md_bg_color: self.theme_cls.backgroundColor
    MDFloatLayout:
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.5
            spacing: dp(0)
            pos_hint: {"right":0.9, "top": 0.9}
            MDLabel:
                text: "Shop"
                adaptive_size: True
                font_style: "cataway"
                role: "large"
                pos_hint: {"center_x":0.5, "center_y": 1}
            MDIconButton:
                icon: "cart-outline"
                size_hint_y: None
                height: dp(50)
                theme_font_size: "Custom"
                font_size: "50sp"
                pos_hint: {"center_x": 0.5, "center_y": 1}
        MDScrollView: #Themes
            do_scroll_x: False
            do_scroll_y: True
            pos_hint: {"center_x":0.5, "center_y":0.5}
            size_hint: 1, 0.8
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                adaptive_height: True
                padding: [dp(self.width%64), dp(50), dp(50), dp(50)]
                spacing: dp(12)
                MDGridLayout:
                    id: grid
                    cols: 2
                    adaptive_height: True
                    size_hint_y: None
                    spacing: dp(20)
                    padding: dp(20)
                    size_hint_x: None
                    width: dp(320)
                    pos_hint: {"center_x": 0.5}
        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back()
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Stats")
                root.manager.current = "Settings"

