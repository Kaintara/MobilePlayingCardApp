<Rules>:
    md_bg_color: self.theme_cls.backgroundColor #Sets the background colour of the screen
    MDFloatLayout:
        MDLabel:
            text: "Rules"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.5
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.7}
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-left"
                pos_hint: {"center_x":0.2,"center_y": 0.8}
                on_release: app.left("Rules")
            Carousel:
                id: carou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "center_y":0.5, "right":0.5}
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: "vertical"
                        padding: dp(30)
                        spacing: dp(60)
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Threes"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Threes!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
                        MDLabel:
                            text: "How to win"
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(25)
                        MDLabel:
                            text: "The aim of the game is to be the first player to get rid of all your cards."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "Card Ranking"
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(25)
                        MDLabel:
                            text: "Cards rank from lowest to highest: 3, 4, 5, 6, 7, 8, 9, Jack, Queen, King, Ace."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "Ace is the highest normal card."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "How to Play"
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(25)
                        MDLabel:
                            text: "Players take turns placing a card onto the discard pile."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "You must play a card equal to or higher than the top card on the pile."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "If you cannot play, you must pick up the entire discard pile and add it to your hand."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "If you can play you draw a card from the deck to maintain three cards until the deck is gone."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "All cards of the same rank are played together apart from a 10 or a 2."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "If four of the same cards are played together it acts as a 10."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "Special Cards"
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(25)
                        MDLabel:
                            text: "2 - Reset Card: A 2 can be played on any card and resets the pile. The next player can play any card."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                        MDLabel:
                            text: "10 - Burn Card: A 10 can be played on any card and burns the pile, removing it from the game. The same player starts a new pile."
                            halign: "left"
                            font_style: "cataway"
                            role: "medium"
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: "vertical"
                        padding: dp(30)
                        spacing: dp(60)
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Rummy"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Rummy!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
                            MDLabel:
                                text: "How to Win"
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                                theme_font_size: "Custom"
                                font_size: dp(25)
                            MDLabel:
                                text: "The first player to gain both a set AND a run using seven cards wins the game."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                            MDLabel:
                                text: "A set is three or four cards of the same rank."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                            MDLabel:
                                text: "A run is three or four consecutive cards of the same suit."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                            MDLabel:
                                text: "Turn Structure"
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                                theme_font_size: "Custom"
                                font_size: dp(25)
                            MDLabel:
                                text: "Each player has two actions per round."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                            MDLabel:
                                text: "First, you must draw a card."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                            MDLabel:
                                text: "Then, you must discard one card from your hand."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "Extra Hint!"
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                                theme_font_size: "Custom"
                                font_size: dp(25)

                            MDLabel:
                                text: "When your opponent discards a card, you have only one immediate opportunity to take that card."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "If you do not take it on that turn, it is no longer available to you."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: "vertical"
                        padding: dp(30)
                        spacing: dp(60)
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Memory"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Memory!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
                            MDLabel:
                                text: "How to Win"
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                                theme_font_size: "Custom"
                                font_size: dp(25)

                            MDLabel:
                                text: "The aim of the game is to collect the most matching pairs of cards."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "How to Match"
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                                theme_font_size: "Custom"
                                font_size: dp(25)

                            MDLabel:
                                text: "All cards are shuffled and placed face down in a grid."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "Each card has exactly one matching pair as it has the same rank and colour."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "Players take turns flipping over two cards."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "If the two cards match, the player keeps the pair and takes another turn."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "If the cards do not match, they are turned face down again and the turn passes to the next player."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"

                            MDLabel:
                                text: "Game End"
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
                                theme_font_size: "Custom"
                                font_size: dp(25)

                            MDLabel:
                                text: "The game ends when all pairs have been found."
                                halign: "left"
                                font_style: "cataway"
                                role: "medium"
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-right"
                pos_hint: {"center_x":0.8,"center_y": 0.8}
                on_release: app.right("Rules")
        MDIconButton: #Back button
            pos_hint: {"center_x":0.05, "center_y": 0.95}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back() #Changes screen to the previous one
        MDIconButton: #Settings Button\
            pos_hint: {"center_x":0.95, "center_y": 0.95}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Rules")
                root.manager.current = "Settings"

<MDShop>:
    md_bg_color: self.theme_cls.backgroundColor #Sets the background colour of the screen
    MDFloatLayout:
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.5
            spacing: dp(0)
            pos_hint: {"right":0.9, "top": 0.9}
            MDLabel:
                text: "Shop"
                adaptive_size: True
                font_style: "cataway"
                role: "large"
                pos_hint: {"center_x":0.5, "center_y": 1}
            MDIconButton:
                icon: "cart-outline"
                size_hint_y: None
                height: dp(50)
                theme_font_size: "Custom"
                font_size: "50sp"
                pos_hint: {"center_x": 0.5, "center_y": 1}
        MDScrollView: #Themes
            do_scroll_x: False
            do_scroll_y: True
            pos_hint: {"center_x":0.5, "center_y":0.5}
            size_hint: 1, 0.8
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                adaptive_height: True
                padding: [dp(self.width%64), dp(50), dp(50), dp(50)]
                spacing: dp(12)
                MDGridLayout:
                    id: grid
                    cols: 2
                    adaptive_height: True
                    size_hint_y: None
                    spacing: dp(20)
                    padding: dp(20)
                    size_hint_x: None
                    width: dp(320)
                    pos_hint: {"center_x": 0.5}
        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back() #Changes screen to the previous one
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Stats")
                root.manager.current = "Settings"

<Stats>:
    md_bg_color: self.theme_cls.backgroundColor #Sets the background colour of the screen
    MDFloatLayout:
        MDLabel:
            text: "Game Stats!"
            adaptive_height: True
            pos_hint: {"center_x":0.5, "top":0.9}
            font_style: "cataway"
            role: "large"
            halign: "center"
        MDBoxLayout:
            id: topbox
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.1
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.8}
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-left"
                pos_hint: {"center_x":0.2}
                on_release: app.left("Stats")
            Carousel:
                id: carou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "top":0.7, "right":0.5}
                MDLabel:
                    text: "All_Time Stats"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Achievements"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Threes"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Rummy"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Memory"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-right"
                pos_hint: {"center_x":0.8,"top":0.7}
                on_release: app.right("Stats")
        MDBoxLayout:
            id: bottombox
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.9
            size_hint_y: 0.1
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.7}
            MDIconButton:
                id: bottom_left
                style: "tonal"
                icon: "chevron-double-left"
                pos_hint: {"center_x":0.05}
                on_release: app.left("Con_Stats")
            Carousel:
                id: conditionalcarou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "top":0.7, "right":0.5}
            MDIconButton:
                id: bottom_right
                style: "tonal"
                icon: "chevron-double-right"
                pos_hint: {"center_x":0.95,"top":0.7}
                on_release: app.right("Con_Stats")
        MDScrollView: #Content Box
            do_scroll_x: False
            do_scroll_y: True
            pos_hint: {"center_x":0.5, "top": 0.55}
            size_hint: 1, 0.55
            MDBoxLayout:
                id: stats
                orientation: "vertical"
                padding: dp(30)
                spacing: dp(60)
                adaptive_height: True
        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back() #Changes screen to the previous one
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Stats")
                root.manager.current = "Settings"

<Settings>:
    md_bg_color: self.theme_cls.backgroundColor #Sets the background colour of the screen
    MDFloatLayout:
        MDLabel:
            text: "Settings"
            adaptive_height: True
            pos_hint: {"center_x":0.5, "top":1}
            font_style: "cataway"
            role: "large"
            halign: "center"

        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.1
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.8}
            MDLabel:
                text: "Bot Difficulty"
                font_style: "cataway"
                role: "small"
                halign: "left"
                valign: "center"
            MDIconButton:
                style: "standard"
                icon: "chevron-double-left"
                pos_hint: {"center_y":0.5}
                on_release: app.left("Settings")
            Carousel:
                id: carou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "center_y":0.5, "right":0.5}
                MDLabel:
                    text: "Beginner"
                    font_style: "cataway"
                    role: "medium"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Easy"
                    font_style: "cataway"
                    role: "medium"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Medium"
                    font_style: "cataway"
                    role: "medium"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Hard"
                    font_style: "cataway"
                    role: "medium"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Expert"
                    font_style: "cataway"
                    role: "medium"
                    halign: "center"
                    valign: "center"
            MDIconButton:
                style: "standard"
                icon: "chevron-double-right"
                pos_hint: {"center_y":0.5}
                on_release: app.right("Settings")
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.1
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.6}
            MDLabel:
                text: "Sfx"
                font_style: "cataway"
                role: "small"
                halign: "left"
                valign: "center"
            MDSwitch:
                id: sfx
                on_active: app.toggle(self,"sfx")
                pos_hint: {"center_x":0.5, "top":0.5}
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.1
            spacing: dp(0)
            pos_hint: {"center_x":0.5, "top":0.5}
            MDLabel:
                text: "Timer"
                font_style: "cataway"
                role: "small"
                halign: "left"
                valign: "center"
            MDSwitch:
                id: timer
                on_active: app.toggle(self,"timer")
                pos_hint: {"center_x":0.5, "top":0.5}
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            adaptive_width: True
            spacing: dp(20)
            pos_hint: {"center_x":0.5, "top": 0.3}
            MDIconButton: #Go to the Games
                style: "tonal"
                icon: "cards-playing-outline"
                on_release: 
                    app.sm_stacky("Settings")
                    root.manager.current = "NewGame"
            MDIconButton: #Go to Game Shop
                style: "tonal"
                icon: "cart-outline"
                on_release: 
                    app.sm_stacky("Settings")
                    app.set_up_shop()
                    root.manager.current = "MDShop"
            MDIconButton: #Go to how to play
                style: "tonal"
                icon: "help"
                on_release: 
                    app.sm_stacky("Settings")
                    root.manager.current = "Rules"
            MDIconButton: #Go to Game stats
                name: "light"
                style: "tonal"
                icon: "chart-donut"
                on_release: 
                    app.sm_stacky("Settings")
                    root.manager.current = "Stats"
        MDButton:
            style: "tonal"
            pos_hint: {"center_x": 0.5, "top":0.1}
            on_release: app.stop()
            MDButtonText:
                text: "Exit Game"
                font_style: "cataway"
                role: "small"
            MDButtonIcon:
                icon: "exit-to-app"

        MDIconButton: #Back Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "backburger"
            on_release: app.back() #Changes screen to the previous one

