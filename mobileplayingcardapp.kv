#:kivy 2.3.0

<MainMenu>:
    md_bg_color: self.theme_cls.surfaceColor
    MDFloatLayout:
        Image: #Main Game Icon
            source: "assets/img/Icon.png"
            pos_hint: {"center_x": 0.5, "center_y": 0.8}
            size_hint: None, None
            size: "250dp", "250dp"
            fit_mode: "scale-down"
        MDBoxLayout:
            orientation: 'vertical'
            pos_hint: {'center_x': .5, 'center_y': .4}
            adaptive_size: True
            spacing: dp(20)
            MDButton: #New Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu")
                    root.manager.current = "NewGame"
                MDButtonText:
                    text: app.resume_game_check()
                    font_style: "cataway"
                    role: "small"
            MDButton: #Shop Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu")
                    app.set_up_shop()
                    root.manager.current = "MDShop"
                MDButtonText:
                    text: "Shop"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Stats Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("Menu")
                    root.manager.current = "Stats"
                MDButtonText:
                    text: "Game Statistics"
                    font_style: "cataway"
                    role: "small"
            MDButton: #Quit Game Button
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: app.stop()
                MDButtonText:
                    text: "Exit Game"
                    font_style: "cataway"
                    role: "small"
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Menu")
                root.manager.current = "Settings"

<NewGame>:
    md_bg_color: self.theme_cls.surfaceColor
    MDFloatLayout:
        MDLabel:
            text: "New Game!"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        Image: #NewGame Icon
            source: "assets/img/NewGame_Icon.png"
            pos_hint: {"center_x": 0.5, "center_y": 0.8}
            size_hint: None, None
            size: "250dp", "250dp"
            fit_mode: "scale-down"
        MDBoxLayout:
            orientation: 'vertical'
            pos_hint: {'center_x': .5, 'center_y': .4}
            adaptive_size: True
            spacing: dp(20)
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    root.manager.current = "MDThrees"
                MDButtonText:
                    text: "Threes"
                    font_style: "cataway"
                    role: "small"
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    root.manager.current = "MDRummy"
                MDButtonText:
                    text: "Rummy"
                    font_style: "cataway"
                    role: "small"
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    root.manager.current = "MDMemory"
                MDButtonText:
                    text: "Memory"
                    font_style: "cataway"
                    role: "small"
            MDButton:
                style: "tonal"
                pos_hint: {"center_x": 0.5}
                on_release: 
                    app.sm_stacky("NewGame")
                    root.manager.current = "Rules"
                MDButtonText:
                    text: "Rules"
                    font_style: "cataway"
                    role: "small"

        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back()
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("NewGame")
                root.manager.current = "Settings"

<Rules>:
    md_bg_color: self.theme_cls.backgroundColor
    MDFloatLayout:
        MDLabel:
            text: "Rules"
            font_style: "cataway"
            role: "large"
            halign: "center"
            pos_hint: {"center_y":0.9, "center_x":0.5}
            adaptive_height: True
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.5
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.7}
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-left"
                pos_hint: {"center_x":0.2,"center_y": 0.8}
                on_release: app.left("Rules")
            Carousel:
                id: carou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "center_y":0.5, "right":0.5}
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: 'vertical'
                        padding: "20dp"
                        spacing: "20dp"
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Threes"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Threes!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: 'vertical'
                        padding: "20dp"
                        spacing: "20dp"
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Rummy"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Rummy!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
                MDScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    MDBoxLayout:
                        orientation: 'vertical'
                        padding: "20dp"
                        spacing: "20dp"
                        adaptive_height: True
                        size_hint_y: None
                        MDLabel:
                            text: "Memory"
                            font_style: "cataway"
                            role: "large"
                            halign: 'center'
                            valign: "top"
                            pos_hint: {"top":0.9, "center_x":0.5}
                            size_hint: None, None
                            height: self.texture_size[1]
                            text_size: self.width*10, None
                        MDLabel:
                            text: "Rules for Memory!"
                            halign: "center"
                            valign: "top"
                            markup: True
                            size_hint_x: 0.8
                            pos_hint: {"center_x": 0.5}
                            text_size: self.width, None
                            size_hint_y: None
                            height: self.texture_size[1]
                            font_style: "cataway"
                            role: "medium"
                            theme_font_size: "Custom"
                            font_size: dp(30)
                            shorten: False
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-right"
                pos_hint: {"center_x":0.8,"center_y": 0.8}
                on_release: app.right("Rules")
        MDIconButton: #Back button
            pos_hint: {"center_x":0.05, "center_y": 0.95}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back()
        MDIconButton: #Settings Button\
            pos_hint: {"center_x":0.95, "center_y": 0.95}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Rules")
                root.manager.current = "Settings"

<MDShop>:
    md_bg_color: self.theme_cls.backgroundColor
    MDFloatLayout:
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.5
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.7}
            MDLabel:
                text: "Shop"
                width: self.parent.width*0.3
                height: self.parent.height*0.3
                font_style: "cataway"
                role: "large"
                pos_hint: {"center_x":0.6, "center_y": 1}
            MDIconButton:
                icon: "cart-outline"
                size_hint_y: None
                height: dp(50)
                theme_font_size: "Custom"
                font_size: "50sp"
                pos_hint: {"center_x": 0.3, "center_y": 1}
        MDScrollView: #Themes
            do_scroll_x: False
            do_scroll_y: True
            pos_hint: {"center_x":0.5, "center_y":0.5}
            size_hint: 1, 1
            MDBoxLayout:
                orientation: "vertical"
                size_hint_y: None
                adaptive_height: True
                padding: [dp(self.width%64), dp(50), dp(50), dp(50)]
                spacing: dp(12)
                MDGridLayout:
                    pos_hint: {"center_x":0.5}
                    md_bg_color: app.theme_cls.surfaceColor
                    id: grid
                    cols: 1 if int((self.width / 64) -2) <= 0 else (int((self.width / 64) -1))
                    adaptive_height: True
                    size_hint_y: None
                    spacing: dp(12)
                    padding: [dp(self.width%64), dp(20), dp(20), dp(20)]
                    on_size:
                        self.cols = 1 if int((self.width / 64) -2) <= 0 else (int((self.width / 64) -1))
        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back()
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Stats")
                root.manager.current = "Settings"

<Stats>:
    md_bg_color: self.theme_cls.backgroundColor
    MDFloatLayout:
        MDLabel:
            text: "Game Stats!"
            adaptive_height: True
            pos_hint: {"center_x":0.5, "top":0.9}
            font_style: "cataway"
            role: "large"
            halign: "center"

        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.1
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.7}
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-left"
                pos_hint: {"center_x":0.2}
                on_release: app.left("Stats")
            Carousel:
                id: carou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "center_y":0.5, "right":0.5}
                MDLabel:
                    text: "All_Time Stats"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Beginner"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Easy"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Medium"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Hard"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Expert"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-right"
                pos_hint: {"center_x":0.8}
                on_release: app.right("Stats")
        MDScrollView: #Themes
            do_scroll_x: False
            do_scroll_y: True
            pos_hint: {"center_x":0.5, "top": 0.55}
            size_hint: 1, 0.55
            MDAnchorLayout:
                anchor_x: "center"
                anchor_y: "center"
                MDBoxLayout:
                    id: stats
                    orientation: "vertical"
                    adaptive_height: True
                    adaptive_width: True
                    spacing: dp(20)
                    pos_hint: {"center_x":0.5, "center_y":0.5, "top": 0.5}
        MDIconButton: #Back button
            pos_hint: {"left":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "arrow-left"
            on_release: 
                app.back()
        MDIconButton: #Settings Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "menu"
            on_release: 
                app.sm_stacky("Stats")
                root.manager.current = "Settings"

<Settings>:
    md_bg_color: self.theme_cls.backgroundColor
    MDFloatLayout:
        MDLabel:
            text: "Bot Difficulty"
            adaptive_height: True
            pos_hint: {"center_x":0.5, "top":0.9}
            font_style: "cataway"
            role: "large"
            halign: "center"

        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            size_hint_x: 0.8
            size_hint_y: 0.1
            spacing: dp(5)
            pos_hint: {"center_x":0.5, "top":0.6}
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-left"
                pos_hint: {"center_x":0.2}
                on_release: app.left("Settings")
            Carousel:
                id: carou
                direction: "right"
                loop: "true"
                pos_hint: {"center_x":0.5, "center_y":0.5, "right":0.5}
                MDLabel:
                    text: "Beginner"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Easy"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Medium"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Hard"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
                MDLabel:
                    text: "Expert"
                    font_style: "cataway"
                    role: "small"
                    halign: "center"
                    valign: "center"
            MDIconButton:
                style: "tonal"
                icon: "chevron-double-right"
                pos_hint: {"center_x":0.8}
                on_release: app.right("Settings")
        MDBoxLayout:
            orientation: "horizontal"
            adaptive_height: True
            adaptive_width: True
            spacing: dp(20)
            pos_hint: {"center_x":0.5, "top": 0.3}
            MDIconButton: #Go to the Games
                style: "tonal"
                icon: "cards-playing-outline"
                on_release: 
                    app.sm_stacky("Settings")
                    root.manager.current = "NewGame"
            MDIconButton: #Go to Game Shop
                style: "tonal"
                icon: "cart-outline"
                on_release: 
                    app.sm_stacky("Settings")
                    app.set_up_shop()
                    root.manager.current = "MDShop"
            MDIconButton: #Go to how to play
                style: "tonal"
                icon: "help"
                on_release: 
                    app.sm_stacky("Settings")
                    root.manager.current = "Rules"
            MDIconButton: #Go to Game stats
                name: "light"
                style: "tonal"
                icon: "chart-donut"
                on_release: 
                    app.sm_stacky("Settings")
                    root.manager.current = "Stats"
        MDButton:
            style: "tonal"
            pos_hint: {"center_x": 0.5, "top":0.1}
            on_release: app.stop()
            MDButtonText:
                text: "Exit Game"
                font_style: "cataway"
                role: "small"
            MDButtonIcon:
                icon: "exit-to-app"

        MDIconButton: #Back Button
            pos_hint: {"right":0.98, "top": 0.98}
            size: dp(48), dp(48)
            icon: "backburger"
            on_release: app.back()